<div class="theme-switcher-float" aria-label="Theme selector">
  <div class="theme-switcher theme-switcher--floating">
    <button type="button" class="theme-switcher__summary" data-theme-summary aria-haspopup="true" aria-expanded="false">
      <span class="theme-switcher__icon" aria-hidden="true">◐</span>
      <span class="sr-only">Theme: <span data-theme-current>Drift</span></span>
    </button>
    <div class="theme-switcher__panel" role="group" aria-label="Select theme">
      <button type="button" class="theme-switcher__option is-active" data-theme-option data-theme-value="drift" aria-pressed="true">Drift</button>
      <button type="button" class="theme-switcher__option" data-theme-option data-theme-value="lumen" aria-pressed="false">Lumen</button>
    </div>
  </div>
</div>
