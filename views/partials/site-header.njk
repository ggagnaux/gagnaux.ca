<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      {% if siteSettings.logo_mode == "animated" %}
        <span class="brand-mark brand-mark--animated">
          <span class="brand-mark__canvas" data-logo-canvas data-logo-animation-mode="{{ siteSettings.logo_animation_mode or 'signal' }}" data-logo-settings="{{ siteSettings.logo_animation_settings_json | escape }}"></span>
        </span>
      {% else %}
        <span class="brand-mark">
          <img src="/assets/img/logo1.png" alt="" class="brand-mark__image">
        </span>
      {% endif %}
      <span>
        <strong>{{ siteSettings.site_title or "Greg Gagnaux" }}</strong>
        <small>{{ siteSettings.site_descriptor or "Creative Technologist • Software Engineer • Visual Artist" }}</small>
      </span>
    </a>
    <button
      type="button"
      class="site-nav-toggle"
      aria-expanded="false"
      aria-controls="site-primary-nav"
      aria-label="Open navigation menu"
      data-site-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="site-nav" aria-label="Primary" id="site-primary-nav" data-site-nav>
      <a href="/" class="{{ 'is-active' if currentPath == '/' else '' }}">Home</a>
      <a href="/projects" class="{{ 'is-active' if '/projects' in currentPath else '' }}">Projects</a>
      <a href="/blog" class="{{ 'is-active' if '/blog' in currentPath else '' }}">Blog</a>
      <a href="/about" class="{{ 'is-active' if currentPath == '/about' else '' }}">About</a>
      <a href="/contact" class="{{ 'is-active' if currentPath == '/contact' else '' }}">Contact</a>
    </nav>
  </div>
</header>
