{% extends "admin-layout.njk" %}

{% block content %}
  <section class="admin-header">
    <div class="panel-heading">
      <div>
        <p class="eyebrow">Admin / Projects</p>
        <h1>{{ formTitle }}</h1>
      </div>
      <a href="/admin/projects" class="button button-secondary">&lt; Back to Projects</a>
    </div>
  </section>
  <section class="admin-panel">
    <form
      action="{{ '/admin/projects/' ~ project.id if project else '/admin/projects' }}"
      method="post"
      enctype="multipart/form-data"
      id="project-edit-form"
    >
      <input type="hidden" name="active_project_tab" value="{{ activeProjectTab or 'details' }}" data-active-project-tab-input>
      <input type="hidden" name="upload_session_id" value="{{ uploadSessionId or '' }}">
    </form>

    <div class="admin-settings-tabs admin-project-tabs" data-project-tabs>
      <div class="admin-settings-tabs__list admin-project-tabs__list" role="tablist" aria-label="Project sections">
        <button
          type="button"
          class="admin-settings-tabs__trigger admin-project-tabs__trigger{% if (activeProjectTab or 'details') == 'details' %} is-active{% endif %}"
          data-project-tab-trigger
          data-project-tab-target="details"
          role="tab"
          aria-selected="{{ 'true' if (activeProjectTab or 'details') == 'details' else 'false' }}"
        >
          Details
        </button>
        <button
          type="button"
          class="admin-settings-tabs__trigger admin-project-tabs__trigger{% if (activeProjectTab or 'details') == 'images' %} is-active{% endif %}"
          data-project-tab-trigger
          data-project-tab-target="images"
          role="tab"
          aria-selected="{{ 'true' if (activeProjectTab or 'details') == 'images' else 'false' }}"
        >
          Images
        </button>
      </div>

      <section class="admin-settings-tabs__panel admin-project-tabs__panel{% if (activeProjectTab or 'details') == 'details' %} is-active{% endif %}" data-project-tab-panel data-project-tab-panel-id="details">
        <div class="inline-fields">
          <label class="admin-floating-field">
            <input type="text" name="title" value="{{ project.title if project else '' }}" form="project-edit-form" placeholder=" " aria-label="Title" required>
            <span class="admin-floating-field__label">Title</span>
          </label>
          <label class="admin-floating-field">
            <input type="text" name="slug" value="{{ project.slug if project else '' }}" form="project-edit-form" placeholder=" " aria-label="Slug">
            <span class="admin-floating-field__label">Slug</span>
          </label>
        </div>
        <label class="admin-floating-field admin-floating-field--textarea">
          <textarea name="summary" rows="3" form="project-edit-form" placeholder=" " aria-label="Summary" required>{{ project.summary if project else '' }}</textarea>
          <span class="admin-floating-field__label">Summary</span>
        </label>
        <div class="field-group">
          <div class="field-heading">
            <button type="button" class="button button-secondary button-compact" data-markdown-help-open>? Markdown Help</button>
          </div>
          <label class="admin-floating-field admin-floating-field--textarea" for="project-description-markdown">
            <textarea id="project-description-markdown" name="description_markdown" rows="5" form="project-edit-form" placeholder=" " aria-label="Description Markdown" required data-markdown-dropzone>{{ project.description_markdown if project else '' }}</textarea>
            <span class="admin-floating-field__label">Description Markdown</span>
          </label>
          {% if mediaLibraryItems and mediaLibraryItems.length %}
            <section class="admin-post-markdown-assets" aria-label="Media library assets for markdown">
              <div class="admin-post-markdown-assets__header">
                <strong>Media Library</strong>
                <span class="muted-text">Drag an icon into the markdown field to insert an image tag.</span>
              </div>
              <div class="admin-post-markdown-assets__grid">
                {% for image in mediaLibraryItems %}
                  <button
                    type="button"
                    class="admin-post-markdown-asset"
                    draggable="true"
                    data-markdown-asset
                    data-markdown-snippet="{{ ('![' ~ (image.alt_text or image.original_name or ('Media image ' ~ loop.index)) ~ '](/uploads/' ~ image.filename ~ ')') | escape }}"
                    aria-label="Insert markdown for media image {{ loop.index }}"
                  >
                    <img src="/uploads/{{ image.filename }}" alt="{{ image.alt_text or image.original_name or ('Media image ' ~ loop.index) }}" class="admin-post-markdown-asset__image">
                    <span class="admin-post-markdown-asset__label">Image {{ loop.index }}</span>
                  </button>
                {% endfor %}
              </div>
            </section>
          {% endif %}
        </div>
        <label class="admin-floating-field">
          <input type="text" name="project_type" value="{{ project.project_type if project else '' }}" form="project-edit-form" placeholder=" " aria-label="Project Type" required>
          <span class="admin-floating-field__label">Project Type</span>
        </label>
        <div class="inline-fields">
          <label class="admin-floating-field">
            <input type="url" name="external_url" value="{{ project.external_url if project else '' }}" form="project-edit-form" placeholder=" " aria-label="External URL">
            <span class="admin-floating-field__label">External URL</span>
          </label>
          <label class="admin-floating-field">
            <input type="text" name="internal_url" value="{{ project.internal_url if project else '' }}" form="project-edit-form" placeholder=" " aria-label="Internal URL">
            <span class="admin-floating-field__label">Internal URL</span>
          </label>
        </div>

      </section>

      <section class="admin-settings-tabs__panel admin-project-tabs__panel admin-project-tabs__panel--images{% if (activeProjectTab or 'details') == 'images' %} is-active{% endif %}" data-project-tab-panel data-project-tab-panel-id="images">
        {% if project %}
          <section class="admin-project-screenshots admin-project-screenshots--tabbed">
            <div class="panel-heading panel-heading--compact">
              <h2>Project Screenshots</h2>
              <p class="muted-text">Manage the images used in this project's homepage carousel.</p>
            </div>
            <form action="/admin/projects/{{ project.id }}/screenshots" method="post" enctype="multipart/form-data" class="admin-form admin-media-upload-form admin-project-screenshot-upload" data-screenshot-upload-form>
              <input type="hidden" name="active_project_tab" value="images">
              <label class="admin-media-upload-control">
                <span class="admin-media-upload-control__label">Add screenshots</span>
                <span class="admin-media-upload-control__hint">Upload one or more new images. They will be appended to the current carousel order. Maximum file size: 8 MB per image.</span>
                <input class="admin-media-upload-control__input" type="file" name="screenshots" accept="image/*" multiple data-screenshot-upload-input>
              </label>
              <p class="error-text" data-screenshot-upload-error hidden></p>
              <div class="form-actions" data-screenshot-upload-actions hidden>
                <button type="submit" class="button button-primary">Upload Screenshots</button>
              </div>
            </form>

            {% if project.screenshots and project.screenshots.length %}
              <p class="muted-text admin-project-screenshot-grid__hint">Drag and drop screenshots to reorder the homepage carousel.</p>
              <form action="/admin/projects/{{ project.id }}/screenshots/delete-selected" method="post" data-screenshot-selection-form data-confirm-delete-form data-confirm-title="Remove Selected Screenshots?" data-confirm-message="This will permanently remove the selected screenshots from &quot;{{ project.title | escape }}&quot;.">
                <input type="hidden" name="active_project_tab" value="images">
                <div class="admin-project-screenshot-grid" data-project-screenshot-sortable data-project-id="{{ project.id }}">
                  {% for screenshot in project.screenshots %}
                    <article class="admin-project-screenshot-card" data-project-screenshot-card data-screenshot-id="{{ screenshot.id }}" draggable="true">
                      <div class="admin-project-screenshot-card__topline">
                        <div class="admin-project-screenshot-card__handle" aria-hidden="true"><span></span><span></span><span></span></div>
                        <label class="admin-project-screenshot-card__selector" aria-label="Select screenshot {{ loop.index }}">
                          <input type="checkbox" name="screenshotIds" value="{{ screenshot.id }}" data-screenshot-select>
                          <span></span>
                        </label>
                      </div>
                      <img src="{{ screenshot.url }}" alt="{{ screenshot.alt_text or project.title ~ ' screenshot ' ~ loop.index }}" class="admin-project-screenshot-card__image">
                      <div class="admin-project-screenshot-card__meta">
                        <strong>Screenshot {{ loop.index }}</strong>
                        <span class="muted-text">{{ screenshot.filename }}</span>
                      </div>
                    </article>
                  {% endfor %}
                </div>
                <div class="form-actions admin-project-screenshot-bulk-actions" data-screenshot-bulk-actions hidden>
                  <button type="submit" class="button button-danger">Remove Selected</button>
                </div>
              </form>
            {% else %}
              <p class="muted-text">No screenshots uploaded yet.</p>
            {% endif %}
          </section>
        {% else %}
          <section class="admin-project-screenshots admin-project-screenshots--tabbed">
            <div class="panel-heading panel-heading--compact">
              <h2>Project Screenshots</h2>
              <p class="muted-text">Upload screenshots now and they will be attached when the project is saved.</p>
            </div>
            <form action="/admin/projects/draft-screenshots" method="post" enctype="multipart/form-data" class="admin-form admin-media-upload-form admin-project-screenshot-upload" data-screenshot-upload-form>
              <input type="hidden" name="upload_session_id" value="{{ uploadSessionId }}">
              <label class="admin-media-upload-control">
                <span class="admin-media-upload-control__label">Project Screenshots</span>
                <span class="admin-media-upload-control__hint">Choose multiple screenshots for this project carousel. Maximum file size: 8 MB per image.</span>
                <input class="admin-media-upload-control__input" type="file" name="screenshots" accept="image/*" multiple data-screenshot-upload-input>
              </label>
              <p class="error-text" data-screenshot-upload-error hidden></p>
              <div class="form-actions" data-screenshot-upload-actions hidden>
                <button type="submit" class="button button-primary">Upload Screenshots</button>
              </div>
            </form>

            {% if draftProjectScreenshots and draftProjectScreenshots.length %}
              <form action="/admin/projects/draft-screenshots/delete-selected" method="post" data-screenshot-selection-form data-confirm-delete-form data-confirm-title="Remove Selected Screenshots?" data-confirm-message="This will permanently remove the selected draft screenshots.">
                <input type="hidden" name="upload_session_id" value="{{ uploadSessionId }}">
                <div class="admin-project-screenshot-grid">
                  {% for screenshot in draftProjectScreenshots %}
                    <article class="admin-project-screenshot-card admin-static-image-card">
                      <div class="admin-project-screenshot-card__topline">
                        <strong>Screenshot {{ loop.index }}</strong>
                        <label class="admin-project-screenshot-card__selector" aria-label="Select screenshot {{ loop.index }}">
                          <input type="checkbox" name="screenshotIds" value="{{ screenshot.id }}" data-screenshot-select>
                          <span></span>
                        </label>
                      </div>
                      <img src="{{ screenshot.url }}" alt="{{ screenshot.alt_text or 'Draft project screenshot ' ~ loop.index }}" class="admin-project-screenshot-card__image">
                      <div class="admin-project-screenshot-card__meta">
                        <span class="muted-text">{{ screenshot.filename }}</span>
                      </div>
                    </article>
                  {% endfor %}
                </div>
                <div class="form-actions admin-project-screenshot-bulk-actions" data-screenshot-bulk-actions hidden>
                  <button type="submit" class="button button-danger">Remove Selected</button>
                </div>
              </form>
            {% else %}
              <p class="muted-text">No screenshots uploaded yet.</p>
            {% endif %}
          </section>
        {% endif %}
      </section>
    </div>

    <div class="form-actions form-actions--project admin-settings-tabs__actions admin-project-tabs__actions">
      <button type="submit" class="button button-primary" form="project-edit-form">Save Project</button>
      {% if project %}
        <form
          action="/admin/projects/{{ project.id }}/delete"
          method="post"
          class="inline-delete inline-delete--project"
          data-confirm-delete-form
          data-confirm-title="Delete Project?"
          data-confirm-message="This will permanently delete the project (details and associated carousel images) for &quot;{{ project.title | escape }}&quot;."
          data-confirm-second-message="Are you sure?"
          data-confirm-extra-checkbox-label="Also delete the entire project folder at /public/projects/{{ project.slug }}"
        >
          <input type="checkbox" name="delete_project_folder" value="1" hidden data-confirm-folder-delete-input>
          <button type="submit" class="button button-danger">Delete Project</button>
        </form>
      {% endif %}
    </div>
  </section>
  {% if project or (draftProjectScreenshots and draftProjectScreenshots.length) %}
    <div class="confirm-modal" data-confirm-modal hidden>
      <div class="confirm-modal__backdrop" data-confirm-cancel></div>
      <div class="confirm-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
        <h2 id="confirm-modal-title" data-confirm-modal-title>Delete item?</h2>
        <p data-confirm-modal-message>Are you sure?</p>
        <label class="confirm-modal__checkbox" data-confirm-extra-checkbox hidden>
          <input type="checkbox" data-confirm-extra-checkbox-input>
          <span data-confirm-extra-checkbox-label></span>
        </label>
        <div class="form-actions">
          <button type="button" class="button button-secondary" data-confirm-cancel>Cancel</button>
          <button type="button" class="button button-danger" data-confirm-accept>Delete</button>
        </div>
      </div>
    </div>
  {% endif %}
  <div class="confirm-modal" data-markdown-help-modal hidden>
    <div class="confirm-modal__backdrop" data-markdown-help-close></div>
    <div class="confirm-modal__dialog markdown-help-modal" role="dialog" aria-modal="true" aria-labelledby="markdown-help-title">
      <h2 id="markdown-help-title">Markdown Help</h2>
      <div class="markdown-help-modal__grid">
        <div>
          <p><strong>Headings</strong></p>
          <pre><code># Main Heading
## Section Heading
### Smaller Heading</code></pre>
        </div>
        <div>
          <p><strong>Emphasis</strong></p>
          <pre><code>**bold**
*italic*
`inline code`</code></pre>
        </div>
        <div>
          <p><strong>Lists</strong></p>
          <pre><code>- First item
- Second item
- Third item</code></pre>
        </div>
        <div>
          <p><strong>Links</strong></p>
          <pre><code>[Link text](https://example.com)</code></pre>
        </div>
        <div>
          <p><strong>Images</strong></p>
          <pre><code>![alt text](url to image)</code></pre>
        </div>
        <div>
          <p><strong>Quotes</strong></p>
          <pre><code>&gt; Quoted text</code></pre>
        </div>
        <div>
          <p><strong>Code Blocks</strong></p>
          <pre><code>```js
console.log("Hello");
```</code></pre>
        </div>
      </div>
      <div class="form-actions">
        <button type="button" class="button button-primary" data-markdown-help-close>Close</button>
      </div>
    </div>
  </div>
{% endblock %}












