{% extends "admin-layout.njk" %}

{% block content %}
  <section class="admin-header">
    <div class="panel-heading">
      <div>
        <p class="eyebrow">Admin / Posts</p>
        <h1>Posts</h1>
      </div>
      <a href="/admin/posts/new" class="button button-primary">New Post</a>
    </div>
  </section>
  <section class="admin-panel">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Featured</th>
            <th>Distribution</th>
            <th>Updated</th>
          </tr>
        </thead>
        <tbody>
          {% for post in posts %}
            <tr>
              <td><a href="/admin/posts/{{ post.id }}/edit">{{ post.title }}</a>{% if post.is_featured %}<span class="admin-feature-badge">Featured</span>{% endif %}</td>
              <td>{{ post.status }}</td>
              <td>{{ "Yes" if post.is_featured else "No" }}</td>
              <td>{{ post.distribution_summary }}</td>
              <td>{{ post.updated_at | date }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
